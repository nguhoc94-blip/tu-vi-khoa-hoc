# Copy to .env and fill in. Never commit real secrets.

DATABASE_URL=postgresql://user:pass@localhost:5432/tuvi

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional footer CTA after free reading
DONATION_TEXT=
DONATION_URL=

# Admin bootstrap: first user when admin_users is empty (see admin_bootstrap)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# Set to 1/true in production (HTTPS)
ADMIN_COOKIE_SECURE=0

# Optional: shown on GET /health for deploy verification
GIT_SHA=
BUILD_TIME=

# Nhịp 3 guardrails (defaults shown in code if unset)
# MAX_WEBHOOK_BODY_BYTES=262144
# MAX_INBOUND_TEXT_CHARS=8000

# Staging only — never enable on production without risk acceptance
# WEBHOOK_SKIP_SIGNATURE_VERIFY=0
